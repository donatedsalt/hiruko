# ---------- Convex ----------
# Public deployment URL used by the Next.js client.
NEXT_PUBLIC_CONVEX_URL=

# ---------- Clerk ----------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Frontend API URL (e.g. https://clerk.your-domain.com or the dev .clerk.accounts.dev URL).
# Consumed by convex/auth.config.ts.
CLERK_FRONTEND_API_URL=

# Signing secret for the /clerk-webhook HTTP action (user.created → seed).
# Set in Convex env: `bunx convex env set CLERK_WEBHOOK_SECRET whsec_...`
CLERK_WEBHOOK_SECRET=

# ---------- Gemini ----------
# Used by /api/chat for the AI consult feature.
GEMINI_API_KEY=
